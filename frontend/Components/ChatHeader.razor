@implements IDisposable
@inject ChatStateService ChatState

<header class="glass-subtle flex flex-wrap items-center justify-between gap-4 rounded-2xl px-4 py-3">
    <div class="flex items-center gap-3">
        <div class="relative flex h-11 w-11 items-center justify-center rounded-2xl bg-emerald-400/20 text-xs font-semibold text-emerald-200">
            @(ChatState.SelectedRoom is null ? "?" : ChatState.SelectedRoom.Name[..1])
            @if (ChatState.SelectedRoom is not null && !ChatState.SelectedRoom.IsGroup)
            {
                <span class="@StatusClasses(ChatState.SelectedRoom.Status)"></span>
            }
        </div>
        <div>
            <div class="text-lg font-semibold">
                @(ChatState.SelectedRoom?.Name ?? "Select a chat")
            </div>
            <div class="text-xs text-muted">
                @HeaderSubtitle
            </div>
        </div>
    </div>

    <div class="flex items-center gap-2 text-xs text-muted">
        @if (ChatState.SelectedRoom is not null)
        {
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1">
                @PresenceLabel
            </span>
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1">
                @(ChatState.SelectedRoom.IsGroup
                    ? "Group chat"
                    : $"Direct · {ChatState.SelectedRoom.PeerId ?? "unknown"}")
            </span>
        }
    </div>
</header>

@code {
    private string HeaderSubtitle => ChatState.SelectedRoom is null
        ? "Pick a contact or group to start"
        : ChatState.SelectedRoom.IsGroup
            ? $"Group chat · {ChatState.SelectedRoom.Name}"
            : $"Direct to · {ChatState.SelectedRoom.Name} ({ChatState.SelectedRoom.PeerId ?? "unknown"})";

    private string PresenceLabel => ChatState.SelectedRoom is null
        ? string.Empty
        : ChatState.SelectedRoom.IsGroup
            ? $"{ChatState.SelectedRoom.MemberCount} members"
            : ChatState.SelectedRoom.Status switch
            {
                PresenceStatus.Online => "Online now",
                PresenceStatus.Away => "Away",
                _ => "Offline"
            };

    private static string StatusClasses(PresenceStatus status) => status switch
    {
        PresenceStatus.Online => "absolute bottom-0 right-0 h-3 w-3 rounded-full border border-slate-900 bg-emerald-400",
        PresenceStatus.Away => "absolute bottom-0 right-0 h-3 w-3 rounded-full border border-slate-900 bg-amber-300",
        _ => "absolute bottom-0 right-0 h-3 w-3 rounded-full border border-slate-900 bg-slate-500"
    };

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
