@implements IDisposable
@inject ChatStateService ChatState

@if (IsOpen)
{
    <div class="fixed inset-0 z-40 bg-slate-950/60" @onclick="OnClose"></div>
}

<aside class="@DrawerClasses">
    <div class="glass-panel flex h-full flex-col gap-4 rounded-3xl p-5">
        <div class="flex items-center justify-between">
            <div>
                <div class="text-sm font-semibold">Notifications</div>
                <div class="text-xs text-muted">@UnreadLabel</div>
            </div>
            <button class="glass-subtle flex h-9 w-9 items-center justify-center rounded-xl text-white/80"
                    @onclick="OnClose" aria-label="Close notifications">
                @((MarkupString)Icons.Close)
            </button>
        </div>

        <button class="glass-subtle rounded-2xl px-3 py-2 text-xs text-white/80"
                @onclick="ChatState.MarkAllNotificationsRead">
            Mark all as read
        </button>

        <div class="flex-1 space-y-3 overflow-y-auto pr-1">
            @if (ChatState.Notifications.Count == 0)
            {
                <div class="text-center text-sm text-muted">No notifications yet.</div>
            }
            else
            {
                @foreach (var notification in ChatState.Notifications)
                {
                    <div class="glass-subtle space-y-1 rounded-2xl px-4 py-3">
                        <div class="flex items-center justify-between text-xs">
                            <span class="font-semibold text-white/90">@notification.Title</span>
                            <span class="text-muted">@notification.Timestamp.ToLocalTime().ToString("HH:mm")</span>
                        </div>
                        <div class="text-xs text-white/80">@notification.Body</div>
                        <div class="flex items-center justify-between text-[11px] text-muted">
                            <span>@NotificationLabel(notification)</span>
                            @if (!notification.IsRead)
                            {
                                <span class="rounded-full bg-emerald-400/20 px-2 py-0.5 text-emerald-200">New</span>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</aside>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string DrawerClasses =>
        $"fixed inset-y-4 right-4 z-50 w-[320px] max-w-[90vw] transition-transform" +
        (IsOpen ? " translate-x-0" : " translate-x-[120%]");

    private string UnreadLabel =>
        ChatState.Notifications.Count(n => !n.IsRead) switch
        {
            0 => "You're all caught up",
            1 => "1 unread alert",
            var count => $"{count} unread alerts"
        };

    private string NotificationLabel(NotificationItem notification)
    {
        if (string.IsNullOrWhiteSpace(notification.RoomId))
        {
            return notification.Kind.ToString();
        }

        var roomName = ChatState.Rooms.FirstOrDefault(room => room.Id == notification.RoomId)?.Name ?? notification.RoomId;
        return $"{notification.Kind} · {roomName}";
    }

    private static class Icons
    {
        public const string Close = "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round' width='18' height='18'><path d='M18 6 6 18'/><path d='M6 6l12 12'/></svg>";
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

}