@inject ChatStateService ChatState

<div class="mt-3 space-y-2">
    @if (ChatState.IsTyping && ChatState.TypingRoomId == ChatState.SelectedRoomId)
    {
        <div class="text-xs text-muted">Someone is typing...</div>
    }

    <div class="glass-panel flex flex-col gap-3 rounded-3xl p-3 sm:flex-row sm:items-end">
        <div class="glass-input flex flex-1 items-center rounded-2xl px-3 py-2">
            <textarea class="h-20 w-full resize-none bg-transparent text-sm text-white/90 placeholder:text-muted focus:outline-none"
                      placeholder="Write a message..." @bind="_message" @bind:event="oninput" @onkeydown="HandleKeydown"></textarea>
        </div>
        <div class="flex items-center gap-2">
            <button class="glass-subtle flex h-10 w-10 items-center justify-center rounded-2xl text-white/70" disabled
                    aria-label="Attach file">
                @((MarkupString)Icons.Paperclip)
            </button>
            <button class="flex h-10 items-center justify-center gap-2 rounded-2xl bg-emerald-400 px-4 text-sm font-semibold text-slate-950 transition hover:bg-emerald-300 disabled:cursor-not-allowed disabled:bg-emerald-400/40 disabled:text-slate-300"
                    disabled="@string.IsNullOrWhiteSpace(_message)" @onclick="SendAsync">
                @((MarkupString)Icons.Send)
                Send
            </button>
        </div>
    </div>
    <div class="text-[11px] text-muted">Enter to send · Shift + Enter for new line</div>
</div>

@code {
    private string _message = string.Empty;

    private async Task HandleKeydown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !args.ShiftKey)
        {
            await SendAsync();
        }
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_message))
        {
            return;
        }

        var content = _message;
        _message = string.Empty;
        await ChatState.SendMessageAsync(content);
    }

    private static class Icons
    {
        public const string Paperclip = "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round' width='18' height='18'><path d='m7.5 12.5 6.9-6.9a3.2 3.2 0 0 1 4.6 4.6l-7.2 7.2a5 5 0 0 1-7.1-7.1l7-7'/></svg>";
        public const string Send = "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round' width='18' height='18'><path d='m22 2-7 20-4-9-9-4 20-7Z'/><path d='M22 2 11 13'/></svg>";
    }
}
