@implements IDisposable
@inject ChatStateService ChatState

<div class="pointer-events-none fixed right-6 top-6 z-[60] flex w-[320px] flex-col gap-3">
    @foreach (var toast in ChatState.Toasts)
    {
        <div class="glass-panel pointer-events-auto animate-[rise_0.25s_ease] rounded-2xl px-4 py-3 text-sm">
            <div class="flex items-start justify-between gap-3">
                <div>
                    <div class="text-xs text-muted">@toast.Kind</div>
                    <div class="font-semibold text-white/90">@toast.Title</div>
                    <div class="text-xs text-white/80">@toast.Body</div>
                </div>
                <button class="text-white/60 hover:text-white" @onclick="() => Dismiss(toast.Id)">
                    @((MarkupString)Icons.Close)
                </button>
            </div>
        </div>
    }
</div>

@code {
    private readonly HashSet<string> _scheduled = new();

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        foreach (var toast in ChatState.Toasts)
        {
            if (_scheduled.Contains(toast.Id))
            {
                continue;
            }

            _scheduled.Add(toast.Id);
            _ = AutoDismissAsync(toast.Id);
        }
    }

    private async Task AutoDismissAsync(string toastId)
    {
        await Task.Delay(4200);
        await InvokeAsync(() => ChatState.DismissToast(toastId));
    }

    private void Dismiss(string toastId) => ChatState.DismissToast(toastId);

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private static class Icons
    {
        public const string Close = "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round' width='14' height='14'><path d='M18 6 6 18'/><path d='M6 6l12 12'/></svg>";
    }
}
